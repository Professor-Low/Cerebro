# ============================================
# Cerebro Memory Configuration
# ============================================
# Copy this file to .env and modify as needed

# ---- Core Settings ----
CEREBRO_DATA_DIR=~/.cerebro/data          # Where Cerebro stores all data
CEREBRO_LOG_LEVEL=INFO                    # DEBUG, INFO, WARNING, ERROR

# ---- Embedding Model ----
CEREBRO_EMBEDDING_MODEL=all-mpnet-base-v2 # Sentence transformer model
CEREBRO_EMBEDDING_DIM=768                 # Embedding dimensions

# ---- Optional: Local LLM for reasoning tools ----
CEREBRO_LLM_URL=                          # Ollama URL (e.g., http://localhost:11434)
CEREBRO_LLM_MODEL=                        # Model name (e.g., qwen3-32b, llama3.1)

# ---- Optional: GPU acceleration ----
CEREBRO_DGX_HOST=                         # Remote GPU host for embeddings

# ---- Optional: Redis (used by Docker deployment) ----
# REDIS_URL=redis://localhost:6379/0
